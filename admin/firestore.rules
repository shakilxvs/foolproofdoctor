rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Submissions ──────────────────────────────────────
    // Public: create only (website form submissions)
    // Admin:  read, update (status changes, notes)
    // Nobody: delete
    match /submissions/{docId} {
      allow create: if
        request.resource.data.keys().hasAll(['firstName','lastName','email','service','status','createdAt'])
        && request.resource.data.status == 'new'
        && request.resource.data.firstName is string
        && request.resource.data.lastName  is string
        && request.resource.data.email     is string
        && request.resource.data.service   is string;

      allow read, update: if
        request.auth != null;

      allow delete: if false;
    }

    // ── Settings / Content ────────────────────────────────
    // Admin only: read + write
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Everything else ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
