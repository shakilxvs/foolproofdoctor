{
  "rewrites": [
    { "source": "/admin",   "destination": "/admin/index.html" },
    { "source": "/admin/",  "destination": "/admin/index.html" },
    { "source": "/mortgage-protection",  "destination": "/index.html" },
    { "source": "/income-protection",    "destination": "/index.html" },
    { "source": "/business-protection",  "destination": "/index.html" },
    { "source": "/family-protection",    "destination": "/index.html" },
    { "source": "/retirement-planning",  "destination": "/index.html" },
    { "source": "/final-expense",        "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff"         },
        { "key": "X-Frame-Options",           "value": "DENY"            },
        { "key": "X-XSS-Protection",          "value": "1; mode=block"   },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag",   "value": "noindex, nofollow" },
        { "key": "Cache-Control",  "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Robots-Tag",   "value": "noindex, nofollow" },
        { "key": "Cache-Control",  "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/js/firebase-config.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type",  "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
